{
  "name": "scoreboard",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "cf:build": "opennextjs-cloudflare build",
    "cf:dev": "wrangler dev",
    "cf:deploy": "opennextjs-cloudflare build && wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply scoreboard --local",
    "db:migrate:remote": "wrangler d1 migrations apply scoreboard --remote"
  },
  "dependencies": {
    "@clerk/nextjs": "^7.2.7",
    "date-fns": "^4.1.0",
    "next": "^15.5.15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250429.0",
    "@opennextjs/cloudflare": "^1.6.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "wrangler": "^4.84.1"
  }
}
